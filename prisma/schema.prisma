// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model DemoRequest {
  id        String   @id @default(cuid())
  name      String
  company   String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("demo_requests")
}

model Loop {
  id            String   @id @default(cuid())
  slug          String   @unique
  status        String   @default("demo")
  brandName     String   @map("brand_name")
  retailPartner String   @default("") @map("retail_partner")
  market        String   @default("en")
  heroTitle     String   @map("hero_title")
  heroSubhead   String   @map("hero_subhead")
  ctaText       String   @default("Submit Your Design") @map("cta_text")
  deadline      String   @default("")
  accentColor   String   @default("#e8325a") @map("accent_color")
  logoUrl       String   @default("") @map("logo_url")
  heroImageUrl  String   @default("") @map("hero_image_url")
  brief         String   @default("")
  guidelines    String   @default("[]")
  prizes        String   @default("[]")
  questions     String   @default("[]")
  autoApprove   Boolean  @default(false) @map("auto_approve")
  pageBg        String   @default("") @map("page_bg")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("loops")
}

model FeedbackResponse {
  id          String   @id @default(cuid())
  entryId     String   @map("entry_id")
  competition String
  questionId  String   @map("question_id")
  answer      String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("feedback_responses")
}

model LoopInquiry {
  id              String   @id @default(cuid())
  brandName       String
  retailPartner   String   @default("")
  productCategory String   @default("")
  market          String   @default("")
  language        String   @default("")
  brief           String   @default("")
  prize           String   @default("")
  campaignType    String   @default("demo")
  contactName     String
  email           String
  phone           String   @default("")
  status          String   @default("new")
  notes           String   @default("")
  createdAt       DateTime @default(now())

  @@map("loopinquiry")
}

model NotifySignup {
  id          String   @id @default(cuid())
  competition String
  email       String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("notify_signups")
}

model Vote {
  id          String   @id @default(cuid())
  entryId     String   @map("entry_id")
  userId      String   @map("user_id")
  competition String
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([entryId, userId])
  @@map("votes")
}

model Entry {
  id           String   @id @default(cuid())
  entryId      String   @unique
  designerName String
  contact      String
  setName      String
  hook         String
  imageUrl     String
  status       String   @default("pending")
  voteCount    Int      @default(0)
  competition  String   @default("biedronka")
  createdAt    DateTime @default(now())
}
